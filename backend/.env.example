# ── AI Provider Configuration ──
# Set at least ONE of the following API keys:

# Option A: OpenAI (recommended — more reliable quota)
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Option B: Google Gemini (free tier, limited quota)
# Get a key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=your-gemini-api-key-here

# ── Provider Selection ──
# "auto"  -> tries OpenAI first, falls back to Gemini
# "openai" -> uses OpenAI only
# "gemini" -> uses Gemini only
AI_PROVIDER=openai

# ── Server ──
PORT=3001
NODE_ENV=development
RATE_LIMIT_MAX=20
